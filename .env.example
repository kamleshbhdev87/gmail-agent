# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# Enable: Gmail API, then create OAuth 2.0 Client ID (Desktop app)
GMAIL_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=YOUR_REFRESH_TOKEN
# To get refresh token: run scripts/get_gmail_token.py (see README)

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Sandbox number (free testing): whatsapp:+14155238886
# Production: your approved Twilio WhatsApp number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number with country code
YOUR_WHATSAPP_NUMBER=whatsapp:+6512345678

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
